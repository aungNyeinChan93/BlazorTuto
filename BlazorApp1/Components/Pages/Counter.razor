@page "/counter";

@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" type="button" @onclick="()=>IncrementCount(currentCount)">Click me</button>

@code {

    [Parameter]
    public int currentCount { get; set; } = 0;

    [Parameter]
    public int IncrementAmount { get; set; } = 1;

    [Parameter]
    public EventCallback<int> CounterFun { get; set; }

    private async Task IncrementCount(int count)
    {
        currentCount += IncrementAmount;
        await CounterFun.InvokeAsync(count);
    }
}
