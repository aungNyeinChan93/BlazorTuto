@page "/"

<PageTitle>Home</PageTitle>

@if (CounterTwo >= 0)
{
    <div>
        <h1>Hello, world!</h1>

        Welcome to your new app.

        <Counter CounterFun="@TestOne" currentCount="10" IncrementAmount="10"/>

        <h4>Message ==> @Message</h4>
        <h3>Counter Two ==> @CounterTwo</h3>
    </div>
}

@code {

    public string? Message { get; set; }
    public int CounterTwo { get; set; } = 0;

    private void TestOne(int count)
    {
        Message = $"Count is {count}";
        CounterTwo = count;
        StateHasChanged(); // ensures UI updates
    }
}
