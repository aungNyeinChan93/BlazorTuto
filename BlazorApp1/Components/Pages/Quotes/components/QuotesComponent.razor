

<div>
    @if (quotes is not null && quotes?.quotes is not null)
    {
        <div class="my-2">
            <h3>Quotes</h3>
            <ul class="list-group">
                @foreach (var quote in quotes.quotes)
                {
                    <li class="list-group-item">@quote.quote</li>
                }
            </ul>
        </div>

    }
    else
    {
        <p class="text-danger">Loading</p>
    }
</div>


@code {
    [Parameter]
    public QuoteModel? quotes { get; set; } 
}
